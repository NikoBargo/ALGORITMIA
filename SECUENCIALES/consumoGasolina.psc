Proceso consumoGasolina
	Definir consumo como Real;
	Definir combustibleUtilizado Como Real;
	Definir Distancia como Real;
	Escribir "Ingrese el combustible que utilizo";
	Leer combustibleUtilizado;
	Distancia <- 1000;
	consumo <- combustibleUtilizado/Distancia;
	Escribir "El consumo de gasolina fue de ", consumo;
FinProceso
