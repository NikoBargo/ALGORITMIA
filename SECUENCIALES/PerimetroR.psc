Proceso PerimetroR
	Definir Ladolargo Como Real;
	Definir LadoCorto como Real;
	Definir Perimetro Como Real;
	Escribir "Ingrese la medida del lado largo";
	Leer Ladolargo;
	Escribir "Ingrese la medida del lado corto ";
	Leer Ladocorto;
	Perimetro <- (Ladolargo*2)+(Ladocorto*2);
	Escribir "El perimetro es ", Perimetro;
FinProceso
