Algoritmo MultiplicarPrimerosVeinteNumeros
    Definir producto Como real;
    Definir i Como Entero;
    
    producto <- 1;
    Para i <- 1 Hasta 20 Con Paso 1 Hacer
        producto <- producto * i;
    FinPara
    Escribir "El resultado de multiplicar los primeros 20 números naturales es: ", producto;
FinAlgoritmo

